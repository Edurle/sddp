# 数据库连接（PostgreSQL 示例）
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# JWT
# JWT_SECRET=your-secret-key
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_HOURS=24
# REMEMBER_TOKEN_EXPIRE_DAYS=30

# 种子数据（首次启动时创建测试数据）
# SDD_SEED_DATA=true

# SMTP（可选）
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
